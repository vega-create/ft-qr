---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import AdSense from '../components/AdSense.astro';
import EventQr from '../components/tools/EventQr';
---
<BaseLayout>
  <SEO slot="head" title="Calendar Event QR Code" description="Generate a QR code for a calendar event." />
  <div class="max-w-4xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-6"><a href="/" class="hover:text-primary-500">Home</a> <span class="mx-2">›</span> <span class="text-gray-900">Calendar Event QR Code</span></nav>
    <h1 class="text-3xl font-bold text-gray-900 mb-6">Calendar Event QR Code</h1>
    <EventQr client:load />
    <AdSense slot="bottom" />
  </div>
</BaseLayout>