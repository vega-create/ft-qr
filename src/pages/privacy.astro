---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
---
<BaseLayout>
  <SEO slot="head" title="Privacy Policy" description="Privacy policy for FreeToolkit QR." />
  <div class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">Privacy Policy</h1>
    <p class="text-sm text-gray-500 mb-8">Last updated: February 2026</p>
    <div class="prose prose-gray max-w-none">
      <h2>Your Data Stays Private</h2><p>All QR code generation is performed in your browser. We do not collect or transmit any data you enter.</p>
      <h2>Analytics</h2><p>We use Google Analytics for anonymous site usage data.</p>
      <h2>Advertising</h2><p>We use Google AdSense. Opt out at <a href="https://www.google.com/settings/ads" class="text-primary-600">Google Ad Settings</a>.</p>
      <h2>Contact</h2><p>Email: <a href="mailto:contact@freetoolkit.cc" class="text-primary-600">contact@freetoolkit.cc</a></p>
    </div>
  </div>
</BaseLayout>
