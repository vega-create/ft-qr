---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import AdSense from '../components/AdSense.astro';
import BitcoinQr from '../components/tools/BitcoinQr';
---
<BaseLayout>
  <SEO slot="head" title="Bitcoin QR Code Generator" description="Generate a QR code for Bitcoin payment addresses." />
  <div class="max-w-4xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-6"><a href="/" class="hover:text-primary-600">Home</a> <span class="mx-2">›</span> <span class="text-gray-900">Bitcoin QR Code Generator</span></nav>
    <h1 class="text-3xl font-bold text-gray-900 mb-6">Bitcoin QR Code Generator</h1>
    <BitcoinQr client:load />
    <AdSense slot="bottom" />
  </div>
</BaseLayout>